rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    match /cards/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /avatars/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
